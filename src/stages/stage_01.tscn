theme_override_font_sizes/font_size = 10
text = "En las estancias de la mazmorra, el valiente aventurero Knight debera reunir cinco monedas doradas para que la antigua puerta se abra y le permita avanzar.

Entre sombras acechan enemigos y trampas traicioneras que lo obligaran a empezar de nuevo si cae en ellas, y aunque porta una espada, nunca la usara, su noble corazon rehuye la violencia.

Solo quien supere cada desafio alcanzara el final y podra liberar a la princesa de lo mas profundo de estas oscuras mazmorras…
                                  ¡Buena suerte aventurero!"
autowrap_mode = 2
justification_flags = 35
